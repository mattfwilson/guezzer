# Valueless template — every value stays EMPTY here (D-11). Real values live in a
# gitignored .env / .env.local, never committed. Copy this file to .env and fill in.
#
# The VITE_ prefix is the mechanical secret boundary (D-09/D-10): VITE_-prefixed
# vars are inlined into the client bundle (public by design); everything else is
# ops/server-only and must NEVER be VITE_-prefixed and NEVER committed.

# Client (public — VITE_-prefixed, safe in bundle — D-09)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Ops / server secrets (NEVER VITE_, NEVER committed — D-10)
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_PASSWORD=
SUPABASE_ACCESS_TOKEN=
SUPABASE_PROJECT_REF=
SUPABASE_URL=

# Per-friend account secrets, keyed by roster slug (D-08). Example slugs:
SEED_EMAIL_MATT=
SEED_PASSWORD_MATT=
SEED_EMAIL_PLACEHOLDER1=
SEED_PASSWORD_PLACEHOLDER1=
